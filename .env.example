# Server
PORT=3000

# Docker Compose credentials (must match docker-compose.yml)
MONGO_USERNAME=admin
MONGO_PASSWORD=admin

# MongoDB connection string (host machine → containerized Mongo)
MONGO_URI=mongodb://${MONGO_USERNAME}:${MONGO_PASSWORD}@localhost:27017/examguard?authSource=admin

# JWT
JWT_SECRET=secret

# ChromaDB
# CHROMA_HOST=localhost
# CHROMA_PORT=8000

# OpenAI (for RAG — will be used later)
# OPENAI_API_KEY=sk-placeholder
